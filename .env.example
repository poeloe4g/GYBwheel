# Copy to .env and fill in. .env is gitignored and never committed.
# Tradier sandbox token (https://developer.tradier.com/) — required.
TRADIER_TOKEN=
# Use the sandbox endpoint by default; set to "production" for a funded account.
TRADIER_ENV=sandbox
# Optional sturdier fundamentals source (FinancialModelingPrep).
FMP_API_KEY=
